{
 "cells": [
  {
   "cell_type": "markdown",
   "id": "146d5a78",
   "metadata": {},
   "source": [
    "## CLIP-RGB Baseline on EuroSAT-MS"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "9329f7b5",
   "metadata": {},
   "source": [
    "# Objectives\n",
    "- Build the EuroSAT-MS test split.\n",
    "- Use only RGB bands **B04, B03, B02** as CLIP input.\n",
    "- Run a frozen **CLIP ViT-B/16** image encoder.\n",
    "- Measure **text-to-image retrieval** with cosine similarity.\n",
    "- Report **Recall@1, Recall@5, Recall@10, mAP**.\n"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "b0dd027d",
   "metadata": {},
   "source": [
    "## Setup project paths and imports"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 1,
   "id": "24dd9ddb",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "DATA_ROOT exists: True\n",
      "CKPT exists: True\n"
     ]
    }
   ],
   "source": [
    "import sys\n",
    "import random\n",
    "from pathlib import Path\n",
    "\n",
    "import clip\n",
    "import matplotlib.pyplot as plt\n",
    "import numpy as np\n",
    "import pandas as pd\n",
    "import torch\n",
    "import torch.nn.functional as F\n",
    "\n",
    "PROJECT_ROOT = Path.cwd().parent if Path.cwd().name == \"notebooks\" else Path.cwd()\n",
    "\n",
    "if str(PROJECT_ROOT) not in sys.path:\n",
    "    sys.path.append(str(PROJECT_ROOT))\n",
    "\n",
    "DATA_ROOT = PROJECT_ROOT / \"data\" / \"EuroSAT_MS\"\n",
    "CKPT_PATH = PROJECT_ROOT / \"checkpoints\" / \"ViT-B-16.pt\"\n",
    "\n",
    "#print(\"PROJECT_ROOT:\", PROJECT_ROOT)\n",
    "#print(\"DATA_ROOT:\", DATA_ROOT)\n",
    "print(\"DATA_ROOT exists:\", DATA_ROOT.exists())\n",
    "#print(\"CKPT_PATH:\", CKPT_PATH)\n",
    "print(\"CKPT exists:\", CKPT_PATH.exists())\n"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "b1f6a56c",
   "metadata": {},
   "source": [
    "## Import dataset and baseline helpers from `src/`"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 2,
   "id": "f32deb28",
   "metadata": {},
   "outputs": [],
   "source": [
    "from src.datasets.eurosat import (\n",
    "    build_eurosat_dataloaders,\n",
    "    get_default_text_queries,\n",
    "    SENTINEL2_BANDS,\n",
    ")\n",
    "from src.utils.visualization import extract_rgb_bands, stretch_for_display\n",
    "from src.experiments.clip_rgb_baseline import run_clip_rgb_text_to_image_baseline\n"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "c29bcca0",
   "metadata": {},
   "source": [
    "## Build test dataloader"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 3,
   "id": "4509a0a6",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Num classes: 10\n",
      "Class names: ['AnnualCrop', 'Forest', 'HerbaceousVegetation', 'Highway', 'Industrial', 'Pasture', 'PermanentCrop', 'Residential', 'River', 'SeaLake']\n",
      "Band names: ['B01', 'B02', 'B03', 'B04', 'B05', 'B06', 'B07', 'B08', 'B8A', 'B09', 'B10', 'B11', 'B12']\n",
      "Total dataset size: 27000\n",
      "Train size: 21600\n",
      "Val size: 2700\n",
      "Test size: 2700\n"
     ]
    }
   ],
   "source": [
    "bundle = build_eurosat_dataloaders(\n",
    "    root=DATA_ROOT,\n",
    "    batch_size=32,\n",
    "    num_workers=0,\n",
    "    train_ratio=0.8,\n",
    "    val_ratio=0.1,\n",
    "    test_ratio=0.1,\n",
    "    seed=42,\n",
    "    normalize=True,\n",
    "    clamp_range=(0.0, 1.0),\n",
    "    transform=None,\n",
    ")\n",
    "\n",
    "dataset = bundle[\"dataset\"]\n",
    "loaders = bundle[\"loaders\"]\n",
    "test_loader = loaders[\"test\"]\n",
    "\n",
    "print(\"Num classes:\", len(dataset.class_names))\n",
    "print(\"Class names:\", dataset.class_names)\n",
    "print(\"Band names:\", SENTINEL2_BANDS)\n",
    "print(\"Total dataset size:\", len(dataset))\n",
    "print(\"Train size:\", len(loaders[\"train\"].dataset))\n",
    "print(\"Val size:\", len(loaders[\"val\"].dataset))\n",
    "print(\"Test size:\", len(loaders[\"test\"].dataset))\n"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "9687a0b7",
   "metadata": {},
   "source": [
    "## Load CLIP model"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 4,
   "id": "afaabce8",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Device: mps\n",
      "CLIP loaded successfully.\n"
     ]
    }
   ],
   "source": [
    "if torch.backends.mps.is_available():\n",
    "    device = \"mps\"\n",
    "else:\n",
    "    device = \"cpu\"\n",
    "\n",
    "print(\"Device:\", device)\n",
    "\n",
    "if not CKPT_PATH.exists():\n",
    "    raise FileNotFoundError(f\"Không tìm thấy checkpoint tại: {CKPT_PATH}\")\n",
    "\n",
    "model, _ = clip.load(str(CKPT_PATH), device=device)\n",
    "model.eval()\n",
    "\n",
    "for p in model.parameters():\n",
    "    p.requires_grad = False\n",
    "\n",
    "print(\"CLIP loaded successfully.\")\n"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "d95daad2",
   "metadata": {},
   "source": [
    "## Encode text prompts"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 5,
   "id": "5bbd005b",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Class prompts:\n",
      " 0: A satellite image of annual crop land.\n",
      " 1: A satellite image of forest.\n",
      " 2: A satellite image of herbaceous vegetation.\n",
      " 3: A satellite image of highway or major road.\n",
      " 4: A satellite image of industrial area.\n",
      " 5: A satellite image of pasture land.\n",
      " 6: A satellite image of permanent crop land.\n",
      " 7: A satellite image of residential area.\n",
      " 8: A satellite image of river.\n",
      " 9: A satellite image of sea or lake.\n",
      "Text feature shape: torch.Size([10, 512])\n"
     ]
    }
   ],
   "source": [
    "class_names = dataset.class_names\n",
    "class_prompts = get_default_text_queries()\n",
    "query_labels = torch.arange(len(class_names), dtype=torch.long)\n",
    "\n",
    "print(\"Class prompts:\")\n",
    "for i, prompt in enumerate(class_prompts):\n",
    "    print(f\"{i:>2}: {prompt}\")\n",
    "\n",
    "with torch.no_grad():\n",
    "    text_tokens = clip.tokenize(class_prompts).to(device)\n",
    "    text_features = model.encode_text(text_tokens).float()\n",
    "    text_features = F.normalize(text_features, dim=-1)\n",
    "\n",
    "print(\"Text feature shape:\", text_features.shape)\n"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "093a749c",
   "metadata": {},
   "source": [
    "## Run CLIP-RGB baseline\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 6,
   "id": "b9768c60",
   "metadata": {},
   "outputs": [
    {
     "data": {
      "application/vnd.jupyter.widget-view+json": {
       "model_id": "983a0fb3216542a2a0c63a975ab0cf60",
       "version_major": 2,
       "version_minor": 0
      },
      "text/plain": [
       "Encoding test gallery:   0%|          | 0/85 [00:00<?, ?it/s]"
      ]
     },
     "metadata": {},
     "output_type": "display_data"
    },
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Gallery feature shape: torch.Size([2700, 512])\n",
      "Gallery labels shape: torch.Size([2700])\n",
      "First 3 labels: [5, 3, 1]\n",
      "First 3 paths: ['/Users/tienesng06/Desktop/ACIVS_ThayBach/data/EuroSAT_MS/Pasture/Pasture_1238.tif', '/Users/tienesng06/Desktop/ACIVS_ThayBach/data/EuroSAT_MS/Highway/Highway_742.tif', '/Users/tienesng06/Desktop/ACIVS_ThayBach/data/EuroSAT_MS/Forest/Forest_2730.tif']\n",
      "\n",
      "=== CLIP-RGB baseline on EuroSAT test split ===\n",
      "R@1: 40.00%\n",
      "R@5: 60.00%\n",
      "R@10: 60.00%\n",
      "mAP: 17.86%\n"
     ]
    }
   ],
   "source": [
    "result = run_clip_rgb_text_to_image_baseline(\n",
    "    test_loader=test_loader,\n",
    "    model=model,\n",
    "    text_features=text_features,\n",
    "    query_labels=query_labels,\n",
    "    device=device,\n",
    "    ks=(1, 5, 10),\n",
    "    image_size=224,\n",
    "    rgb_indices=(3, 2, 1),  # B04, B03, B02\n",
    "    show_progress=True,\n",
    ")\n",
    "\n",
    "gallery = result[\"gallery\"]\n",
    "metrics = result[\"metrics\"]\n",
    "similarity_matrix = result[\"similarity_matrix\"]\n",
    "ranked_indices = result[\"ranked_indices\"]\n",
    "ranked_relevance = result[\"ranked_relevance\"]\n",
    "per_query_results = result[\"per_query_results\"]\n",
    "\n",
    "print(\"Gallery feature shape:\", gallery[\"features\"].shape)\n",
    "print(\"Gallery labels shape:\", gallery[\"labels\"].shape)\n",
    "print(\"First 3 labels:\", gallery[\"labels\"][:3].tolist())\n",
    "print(\"First 3 paths:\", gallery[\"paths\"][:3])\n",
    "\n",
    "print(\"\\n=== CLIP-RGB baseline on EuroSAT test split ===\")\n",
    "for k, v in metrics.items():\n",
    "    print(f\"{k}: {v:.2f}%\")\n"
   ]
  },
