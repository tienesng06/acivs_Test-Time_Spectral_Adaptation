   ],
   "source": [
    "SEEDS = [42, 43, 44, 45, 46]\n",
    "\n",
    "def set_all_seeds(seed: int):\n",
    "    random.seed(seed)\n",
    "    np.random.seed(seed)\n",
    "    torch.manual_seed(seed)\n",
    "    if torch.cuda.is_available():\n",
    "        torch.cuda.manual_seed_all(seed)\n",
    "\n",
    "\n",
    "@torch.no_grad()\n",
    "def run_clip_rgb_eval_for_seed(seed: int):\n",
    "    set_all_seeds(seed)\n",
    "\n",
    "    bundle = build_eurosat_dataloaders(\n",
    "        root=DATA_ROOT,\n",
    "        batch_size=32,\n",
    "        num_workers=0,\n",
    "        train_ratio=0.8,\n",
    "        val_ratio=0.1,\n",
    "        test_ratio=0.1,\n",
    "        seed=seed,\n",
    "        normalize=True,\n",
    "        clamp_range=(0.0, 1.0),\n",
    "        transform=None,\n",
    "    )\n",
    "\n",
    "    dataset = bundle[\"dataset\"]\n",
    "    test_loader = bundle[\"loaders\"][\"test\"]\n",
    "\n",
    "    class_prompts = get_default_text_queries()\n",
    "    query_labels = torch.arange(len(dataset.class_names), dtype=torch.long)\n",
    "\n",
    "    text_tokens = clip.tokenize(class_prompts).to(device)\n",
    "    text_features = model.encode_text(text_tokens).float()\n",
    "    text_features = F.normalize(text_features, dim=-1)\n",
    "\n",
    "    result = run_clip_rgb_text_to_image_baseline(\n",
    "        test_loader=test_loader,\n",
    "        model=model,\n",
    "        text_features=text_features,\n",
    "        query_labels=query_labels,\n",
    "        device=device,\n",
    "        ks=(1, 5, 10),\n",
    "        image_size=224,\n",
    "        rgb_indices=(3, 2, 1),\n",
    "        show_progress=False,\n",
    "    )\n",
    "\n",
    "    metrics = result[\"metrics\"]\n",
    "    gallery = result[\"gallery\"]\n",
    "\n",
    "    if torch.cuda.is_available():\n",
    "        torch.cuda.empty_cache()\n",
    "    if hasattr(torch, \"mps\") and torch.backends.mps.is_available():\n",
    "        try:\n",
    "            torch.mps.empty_cache()\n",
    "        except Exception:\n",
    "            pass\n",
    "\n",
    "    return {\n",
    "        \"seed\": seed,\n",
    "        \"num_queries\": int(len(query_labels)),\n",
    "        \"num_gallery_images\": int(len(gallery[\"labels\"])),\n",
    "        \"R@1\": float(metrics[\"R@1\"]),\n",
    "        \"R@5\": float(metrics[\"R@5\"]),\n",
    "        \"R@10\": float(metrics[\"R@10\"]),\n",
    "        \"mAP\": float(metrics[\"mAP\"]),\n",
    "    }\n",
    "\n",
    "\n",
    "all_results = []\n",
    "for seed in SEEDS:\n",
    "    print(f\"Running seed = {seed} ...\")\n",
    "    res = run_clip_rgb_eval_for_seed(seed)\n",
    "    all_results.append(res)\n",
    "    print(\n",
    "        f\"  R@1={res['R@1']:.2f}% | \"\n",
    "        f\"R@5={res['R@5']:.2f}% | \"\n",
    "        f\"R@10={res['R@10']:.2f}% | \"\n",
    "        f\"mAP={res['mAP']:.2f}%\"\n",
    "    )\n",
    "\n",
    "results_df = pd.DataFrame(all_results)\n",
    "print(\"\\n=== Per-seed results ===\")\n",
    "display(results_df)\n",
    "\n",
    "metric_cols = [\"R@1\", \"R@5\", \"R@10\", \"mAP\"]\n",
    "summary_rows = []\n",
    "\n",
    "for col in metric_cols:\n",
    "    mean_val = results_df[col].mean()\n",
    "    std_val = results_df[col].std(ddof=1)\n",
    "    summary_rows.append(\n",
    "        {\n",
    "            \"metric\": col,\n",
    "            \"mean_percent\": round(mean_val, 2),\n",
    "            \"std_percent\": round(std_val, 2),\n",
    "            \"mean ± std\": f\"{mean_val:.2f} ± {std_val:.2f}\",\n",
    "        }\n",
    "    )\n",
    "\n",
    "multi_seed_summary_df = pd.DataFrame(summary_rows)\n",
    "print(\"\\n=== Mean ± std across seeds ===\")\n",
    "display(multi_seed_summary_df)\n"
   ]
  },
