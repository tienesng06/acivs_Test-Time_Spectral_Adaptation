     ]
    }
   ],
   "source": [
    "idx_to_class = {i: name for i, name in enumerate(class_names)}\n",
    "\n",
    "for q_idx, prompt in enumerate(class_prompts):\n",
    "    print(\"=\" * 100)\n",
    "    print(f\"Query {q_idx}: {prompt}\")\n",
    "    print(f\"Target class: {idx_to_class[q_idx]}\")\n",
    "    print(\"Top-5 retrieved images:\")\n",
    "\n",
    "    top5_gallery_idx = ranked_indices[q_idx, :5].tolist()\n",
    "    for rank, g_idx in enumerate(top5_gallery_idx, start=1):\n",
    "        retrieved_label = int(gallery[\"labels\"][g_idx].item())\n",
    "        retrieved_name = gallery[\"label_names\"][g_idx]\n",
    "        score = float(similarity_matrix[q_idx, g_idx].item())\n",
    "        is_relevant = retrieved_label == q_idx\n",
    "\n",
    "        print(\n",
    "            f\"  {rank}. {retrieved_name:>22} | \"\n",
    "            f\"cosine={score:.4f} | relevant={is_relevant} | path={gallery['paths'][g_idx]}\"\n",
    "        )\n"
   ]
  },
